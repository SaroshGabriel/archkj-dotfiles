# в”Ђв”Ђ ALIASES в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
aliases() {
  local Y='\033[1;33m' G='\033[0;32m' N='\033[0m' D='\033[0;90m'
  local section='' pad=26
  while IFS= read -r line; do
    if [[ "$line" =~ ^#[[:space:]]в”Ђв”Ђ[[:space:]](.+) ]]; then
      section="${BASH_REMATCH[1]}"
      echo -e "\n${Y}в”Ђв”Ђ ${section}${N}"
    elif [[ "$line" =~ ^alias[[:space:]]([^=]+)=(.+) ]]; then
      local name="${BASH_REMATCH[1]}"
      local val="${BASH_REMATCH[2]//\'/}"
      val="${val//\"/}"
      val="${val%%  #*}"
      [[ ${#val} -gt 52 ]] && val="${val:0:49}..."
      printf "  ${G}%-${pad}s${N} ${D}%s${N}\n" "$name" "$val"
    fi
  done < ~/.bashrc
  echo ''
}

